{
  "manifest_version": 3,
  "name": "AutoGrader Universal Scraper",
  "version": "3.0.0",
  "description": "Intelligent universal data extraction with platform auto-detection, stealth browsing, multi-page crawling, and semantic analysis",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "cookies",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:5173/*",
    "https://onpage.dev/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background-main.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "advanced-settings.js",
        "data-extractor.js",
        "session-manager.js",
        "dynamic-content-handler.js",
        "anti-detection.js",
        "performance-manager.js",
        "enhanced-integration.js",
        "autograder-integration.js",
        "content.js",
        "content/privacy-guard.js",
        "content/strategies/dashboard.js",
        "content/strategies/course.js",
        "content/strategies/assignment.js",
        "content/strategies/grades.js",
        "content/parser/normalizer.js",
        "content/parser/validators.js",
        "content/router.js",
        "content/moodle-auto-scraper.js",
        "content/moodle-content-main.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "enhanced-popup.html",
    "default_title": "AutoGrader Universal Scraper",
    "default_icon": {
      "16": "icons/OnPage.png",
      "32": "icons/OnPage.png",
      "48": "icons/OnPage.png",
      "128": "icons/OnPage.png"
    }
  },
  "options_page": "reports.html",
  "icons": {
    "16": "icons/OnPage.png",
    "32": "icons/OnPage.png",
    "48": "icons/OnPage.png",
    "128": "icons/OnPage.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "core/SiteDetector.js",
        "core/StealthEngine.js",
        "core/UniversalScraper.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}